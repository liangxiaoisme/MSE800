        </mxCell>
        <mxCell id="s1_deliv" value="Working Django API server with all CRUD endpoints, seeded database, JWT auth flow verified via curl/Postman." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=11;fontColor=#334155;" vertex="1" parent="1">
