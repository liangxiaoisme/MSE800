        <mxCell id="s1_obj" value="Scaffold the full-stack skeleton: Django project, PostgreSQL schema, JWT auth, and core REST APIs for training, compliance, and incidents." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=11;fontColor=#334155;" vertex="1" parent="1">
          <mxGeometry x="340" y="262" width="410" height="30" as="geometry" />
