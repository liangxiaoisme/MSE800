        <mxCell id="r1_title" value="Sprint 1 Retrospective" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=14;fontStyle=1;fontColor=#ea580c;" vertex="1" parent="1">
