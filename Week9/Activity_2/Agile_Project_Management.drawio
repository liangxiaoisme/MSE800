        <mxCell id="s2_obj" value="Build the React frontend (login, dashboard, training, compliance, incidents) and implement the RAG chatbot pipeline with OpenRouter." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=11;fontColor=#334155;" vertex="1" parent="1">
