        </mxCell>
        <mxCell id="r1_went_items" value="&amp;bull; Django + DRF scaffold was fast and clean&lt;br&gt;&amp;bull; 5-app modular structure kept code organised&lt;br&gt;&amp;bull; pgvector integration worked first try&lt;br&gt;&amp;bull; Seed data made manual testing easy" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=10;fontColor=#334155;" vertex="1" parent="1">
          <mxGeometry x="870" y="312" width="285" height="55" as="geometry" />
        </mxCell>
        <mxCell id="r1_improve" value="🔧 To improve" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;whiteSpace=wrap;rounded=0;fontSize=12;fontStyle=1;fontColor=#dc2626;" vertex="1" parent="1">
