          <mxGeometry x="340" y="738" width="410" height="22" as="geometry" />
        </mxCell>
        <mxCell id="s2_tasks" value="&amp;bull; Scaffold React + Vite project with React Router + Axios&lt;br&gt;&amp;bull; Implement JWT login page and AuthContext (token store + role guard)&lt;br&gt;&amp;bull; Build Dashboard (summary cards: modules, compliance, incidents)&lt;br&gt;&amp;bull; Build Training pages (list → detail → quiz → submit score)&lt;br&gt;&amp;bull; Build Compliance page (status list with color-coded badges)&lt;br&gt;&amp;bull; Build Incidents pages (list + report form + admin resolve button)&lt;br&gt;&amp;bull; Implement RAG ingestion (chunking + fastembed + pgvector store)&lt;br&gt;&amp;bull; Implement chatbot ask endpoint (retrieve → prompt → OpenRouter → fallback)&lt;br&gt;&amp;bull; Build floating ChatWidget component (slide-out panel, send/response)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=11;fontColor=#334155;" vertex="1" parent="1">
