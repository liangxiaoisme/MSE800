          <mxGeometry x="340" y="298" width="410" height="22" as="geometry" />
        </mxCell>
        <mxCell id="s1_tasks" value="&amp;bull; Scaffold Django project + 5 apps (accounts, training, compliance, incidents, chatbot)&lt;br&gt;&amp;bull; Define 11 PostgreSQL models with pgvector extension&lt;br&gt;&amp;bull; Implement JWT auth (login, token refresh, role-based access)&lt;br&gt;&amp;bull; Build training API (module list/detail, enrollment, quiz submission)&lt;br&gt;&amp;bull; Build compliance API (requirements + on-read status computation)&lt;br&gt;&amp;bull; Build incidents API (staff create, admin update status)&lt;br&gt;&amp;bull; Seed database with demo data (3 modules, 3 requirements, 5 docs)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;whiteSpace=wrap;rounded=0;fontSize=11;fontColor=#334155;" vertex="1" parent="1">
