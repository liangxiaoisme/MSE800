                <mxCell id="p1_num" value="01" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=44;fontStyle=1;fontColor=#ffffff;opacity=25;" parent="1" vertex="1">
                    <mxGeometry x="190" y="135" width="70" height="50" as="geometry"/>
                </mxCell>
                <mxCell id="p1_title" value="Requirements Analysis" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=19;fontStyle=1;fontColor=#ffffff;" parent="1" vertex="1">
                    <mxGeometry x="270" y="132" width="350" height="28" as="geometry"/>
                </mxCell>
                <mxCell id="p1_time" value="Week 1" style="text;html=1;fillColor=#1d4ed8;align=center;verticalAlign=middle;rounded=6;fontSize=10;fontColor=#ffffff;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="270" y="165" width="55" height="20" as="geometry"/>
                </mxCell>
                <mxCell id="p1_desc" value="&amp;bull; Gather HIPAA &amp;amp; GDPR compliance needs, map to measurable features&lt;br&gt;&amp;bull; Define 10 safety-reporting requirements with incident severity categories&lt;br&gt;&amp;bull; Map user roles: Staff (training, reporting) vs Admin (management, review)&lt;br&gt;&amp;bull; Establish non-functional: JWT auth, CORS, HTTPS, responsive design&lt;br&gt;&amp;bull; Document SRS with acceptance criteria for all business metrics" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=10;fontColor=#dbeafe;" parent="1" vertex="1">
                    <mxGeometry x="200" y="190" width="700" height="65" as="geometry"/>
                </mxCell>
                <mxCell id="a12" value="" style="endArrow=block;endFill=1;endSize=12;html=1;strokeWidth=3;strokeColor=#64748b;" parent="1" edge="1">
                    <mxGeometry relative="1" as="geometry">
                        <mxPoint x="550" y="268" as="sourcePoint"/>
                        <mxPoint x="550" y="295" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="p2" value="" style="rounded=10;arcSize=6;fillColor=#7c3aed;strokeColor=#6d28d9;strokeWidth=2;shadow=1;" parent="1" vertex="1">
                    <mxGeometry x="180" y="300" width="740" height="140" as="geometry"/>
                </mxCell>
                <mxCell id="p2_num" value="02" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=44;fontStyle=1;fontColor=#ffffff;opacity=25;" parent="1" vertex="1">
                    <mxGeometry x="190" y="310" width="70" height="50" as="geometry"/>
                </mxCell>
                <mxCell id="p2_title" value="System Design" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=19;fontStyle=1;fontColor=#ffffff;" parent="1" vertex="1">
                    <mxGeometry x="270" y="307" width="350" height="28" as="geometry"/>
                </mxCell>
                <mxCell id="p2_time" value="Week 2" style="text;html=1;fillColor=#6d28d9;align=center;verticalAlign=middle;rounded=6;fontSize=10;fontColor=#ffffff;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="270" y="340" width="55" height="20" as="geometry"/>
                </mxCell>
                <mxCell id="p2_desc" value="&amp;bull; 3-tier B/S architecture: React SPA → Django REST API → PostgreSQL+pgvector&lt;br&gt;&amp;bull; OOP class hierarchy: 5 Django apps, User inheritance, Document-Chunk composition&lt;br&gt;&amp;bull; DB schema: 11 tables, pgvector VectorField(384), FK constraints, indexes&lt;br&gt;&amp;bull; API route design: 15+ REST endpoints with JWT chain &amp;amp; role-based permissions&lt;br&gt;&amp;bull; UI/UX wireframes: 6 screens (Login → Dashboard → Training → Compliance → Incidents → Chatbot)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=10;fontColor=#ede9fe;" parent="1" vertex="1">
                    <mxGeometry x="200" y="365" width="700" height="65" as="geometry"/>
                </mxCell>
                <mxCell id="a23" value="" style="endArrow=block;endFill=1;endSize=12;html=1;strokeWidth=3;strokeColor=#64748b;" parent="1" edge="1">
                    <mxGeometry relative="1" as="geometry">
                        <mxPoint x="550" y="443" as="sourcePoint"/>
                        <mxPoint x="550" y="470" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="p3" value="" style="rounded=10;arcSize=6;fillColor=#0891b2;strokeColor=#0e7490;strokeWidth=2;shadow=1;" parent="1" vertex="1">
                    <mxGeometry x="180" y="475" width="740" height="140" as="geometry"/>
                </mxCell>
                <mxCell id="p3_num" value="03" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=44;fontStyle=1;fontColor=#ffffff;opacity=25;" parent="1" vertex="1">
                    <mxGeometry x="190" y="485" width="70" height="50" as="geometry"/>
                </mxCell>
                <mxCell id="p3_title" value="Implementation &amp;amp; Development" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=19;fontStyle=1;fontColor=#ffffff;" parent="1" vertex="1">
                    <mxGeometry x="270" y="482" width="400" height="28" as="geometry"/>
                </mxCell>
                <mxCell id="p3_time" value="Weeks 3–4" style="text;html=1;fillColor=#0e7490;align=center;verticalAlign=middle;rounded=6;fontSize=10;fontColor=#ffffff;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="270" y="515" width="65" height="20" as="geometry"/>
                </mxCell>
                <mxCell id="p3_desc" value="&amp;bull; Scaffold Django 5 project (5 apps), DRF, SimpleJWT, PostgreSQL+pgvector, Gunicorn&lt;br&gt;&amp;bull; Build 15+ REST endpoints: auth → training CRUD → quiz grading → compliance status → incident workflow&lt;br&gt;&amp;bull; Build React 18 + Vite SPA: 6 screens, Axios JWT interceptor, sidebar nav, floating ChatWidget&lt;br&gt;&amp;bull; RAG pipeline: fastembed (bge-small-en, 384-dim) → pgvector L2Distance → OpenRouter Llama 4 Maverick&lt;br&gt;&amp;bull; Seed: 3 modules × 3 questions, 3 compliance requirements, 5 knowledge-base docs, 2 demo users" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=10;fontColor=#cffafe;" parent="1" vertex="1">
                    <mxGeometry x="200" y="540" width="700" height="65" as="geometry"/>
                </mxCell>
                <mxCell id="a34" value="" style="endArrow=block;endFill=1;endSize=12;html=1;strokeWidth=3;strokeColor=#64748b;" parent="1" edge="1">
                    <mxGeometry relative="1" as="geometry">
                        <mxPoint x="550" y="618" as="sourcePoint"/>
                        <mxPoint x="550" y="645" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="p4" value="" style="rounded=10;arcSize=6;fillColor=#ea580c;strokeColor=#c2410c;strokeWidth=2;shadow=1;" parent="1" vertex="1">
                    <mxGeometry x="180" y="650" width="740" height="140" as="geometry"/>
                </mxCell>
                <mxCell id="p4_num" value="04" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=44;fontStyle=1;fontColor=#ffffff;opacity=25;" parent="1" vertex="1">
                    <mxGeometry x="190" y="660" width="70" height="50" as="geometry"/>
                </mxCell>
                <mxCell id="p4_title" value="Testing &amp;amp; Validation" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=19;fontStyle=1;fontColor=#ffffff;" parent="1" vertex="1">
                    <mxGeometry x="270" y="657" width="350" height="28" as="geometry"/>
                </mxCell>
                <mxCell id="p4_time" value="Week 5" style="text;html=1;fillColor=#9a3412;align=center;verticalAlign=middle;rounded=6;fontSize=10;fontColor=#ffffff;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="270" y="690" width="55" height="20" as="geometry"/>
                </mxCell>
                <mxCell id="p4_desc" value="&amp;bull; Unit testing: Django test cases for all API endpoints (auth, CRUD, quiz, compliance)&lt;br&gt;&amp;bull; Integration testing: React ↔ Django ↔ PostgreSQL full-stack data-flow validation&lt;br&gt;&amp;bull; Security testing: JWT expiry, role guard, CORS origin validation, SQL injection prevention&lt;br&gt;&amp;bull; RAG accuracy: top-5 relevance scoring, source-citation verification across 10 sample questions&lt;br&gt;&amp;bull; UAT: walk all 10 business metrics; cross-browser &amp;amp; responsive (Chrome, Firefox, Edge)" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=10;fontColor=#fef3c7;" parent="1" vertex="1">
                    <mxGeometry x="200" y="715" width="700" height="65" as="geometry"/>
                </mxCell>
                <mxCell id="a45" value="" style="endArrow=block;endFill=1;endSize=12;html=1;strokeWidth=3;strokeColor=#64748b;" parent="1" edge="1">
                    <mxGeometry relative="1" as="geometry">
                        <mxPoint x="550" y="793" as="sourcePoint"/>
                        <mxPoint x="550" y="820" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="p5" value="" style="rounded=10;arcSize=6;fillColor=#dc2626;strokeColor=#b91c1c;strokeWidth=2;shadow=1;" parent="1" vertex="1">
                    <mxGeometry x="180" y="825" width="740" height="140" as="geometry"/>
                </mxCell>
                <mxCell id="p5_num" value="05" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=44;fontStyle=1;fontColor=#ffffff;opacity=25;" parent="1" vertex="1">
                    <mxGeometry x="190" y="835" width="70" height="50" as="geometry"/>
                </mxCell>
                <mxCell id="p5_title" value="Deployment &amp;amp; Go-Live" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=19;fontStyle=1;fontColor=#ffffff;" parent="1" vertex="1">
                    <mxGeometry x="270" y="832" width="350" height="28" as="geometry"/>
                </mxCell>
                <mxCell id="p5_time" value="Week 6" style="text;html=1;fillColor=#991b1b;align=center;verticalAlign=middle;rounded=6;fontSize=10;fontColor=#ffffff;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="270" y="865" width="55" height="20" as="geometry"/>
                </mxCell>
                <mxCell id="p5_desc" value="&amp;bull; Deploy Django to Render: Gunicorn, env vars (DATABASE_URL, SECRET_KEY, OPENROUTER_KEY)&lt;br&gt;&amp;bull; Deploy React to Vercel: VITE_API_URL, SPA rewrite rules, auto-deploy on Git push&lt;br&gt;&amp;bull; Provision Supabase PostgreSQL: pgvector extension, transaction-pooling (port 6543), 500MB tier&lt;br&gt;&amp;bull; Configure OpenRouter API key + run ingest_docs on Render production instance&lt;br&gt;&amp;bull; Cold-start UX: frontend warm-up → &amp;quot;Waking server…&amp;quot; → retry; smoke test all endpoints" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=10;fontColor=#fee2e2;" parent="1" vertex="1">
                    <mxGeometry x="200" y="890" width="700" height="65" as="geometry"/>
                </mxCell>
                <mxCell id="a56" value="" style="endArrow=block;endFill=1;endSize=12;html=1;strokeWidth=3;strokeColor=#64748b;" parent="1" edge="1">
                    <mxGeometry relative="1" as="geometry">
                        <mxPoint x="550" y="968" as="sourcePoint"/>
                        <mxPoint x="550" y="995" as="targetPoint"/>
                    </mxGeometry>
                </mxCell>
                <mxCell id="p6" value="" style="rounded=10;arcSize=6;fillColor=#059669;strokeColor=#047857;strokeWidth=2;shadow=1;" parent="1" vertex="1">
                    <mxGeometry x="180" y="1000" width="740" height="140" as="geometry"/>
                </mxCell>
                <mxCell id="p6_num" value="06" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=44;fontStyle=1;fontColor=#ffffff;opacity=25;" parent="1" vertex="1">
                    <mxGeometry x="190" y="1010" width="70" height="50" as="geometry"/>
                </mxCell>
                <mxCell id="p6_title" value="Maintenance &amp;amp; Support" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=19;fontStyle=1;fontColor=#ffffff;" parent="1" vertex="1">
                    <mxGeometry x="270" y="1007" width="350" height="28" as="geometry"/>
                </mxCell>
                <mxCell id="p6_time" value="Week 7" style="text;html=1;fillColor=#047857;align=center;verticalAlign=middle;rounded=6;fontSize=10;fontColor=#ffffff;fontStyle=1;" parent="1" vertex="1">
                    <mxGeometry x="270" y="1040" width="55" height="20" as="geometry"/>
                </mxCell>
                <mxCell id="p6_desc" value="&amp;bull; Monitor Render runtime logs &amp;amp; Supabase database performance metrics&lt;br&gt;&amp;bull; Apply bug fixes &amp;amp; dependency security patches (Django, React, npm packages)&lt;br&gt;&amp;bull; RAG tuning: optimise chunk size/overlap, iterate prompt template for answer quality&lt;br&gt;&amp;bull; Track HIPAA/GDPR regulatory changes → update knowledge-base docs → re-run ingest_docs&lt;br&gt;&amp;bull; Periodic audits: user access reviews, API security scans, data integrity; SLA: 48-hr critical response" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=10;fontColor=#d1fae5;" parent="1" vertex="1">
                    <mxGeometry x="200" y="1065" width="700" height="65" as="geometry"/>
                </mxCell>
                <mxCell id="kp_bg" value="" style="rounded=8;arcSize=4;fillColor=#f1f5f9;strokeColor=#e2e8f0;strokeWidth=1;" parent="1" vertex="1">
                    <mxGeometry x="180" y="1175" width="740" height="130" as="geometry"/>
                </mxCell>
                <mxCell id="kp_title" value="Key Principles of Waterfall" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=15;fontStyle=1;fontColor=#1e293b;" parent="1" vertex="1">
                    <mxGeometry x="210" y="1185" width="300" height="22" as="geometry"/>
                </mxCell>
                <mxCell id="kp1" value="✓ Sequential, structured phases — each completes before the next begins" style="text;html=1;strokeColor=none;fillColor=#ffffff;align=center;verticalAlign=middle;rounded=8;fontSize=10;fontColor=#1e293b;shadow=1;" parent="1" vertex="1">
                    <mxGeometry x="210" y="1218" width="340" height="34" as="geometry"/>
                </mxCell>
                <mxCell id="kp2" value="✓ Comprehensive documentation at every stage" style="text;html=1;strokeColor=none;fillColor=#ffffff;align=center;verticalAlign=middle;rounded=8;fontSize=10;fontColor=#1e293b;shadow=1;" parent="1" vertex="1">
                    <mxGeometry x="570" y="1218" width="320" height="34" as="geometry"/>
                </mxCell>
                <mxCell id="kp3" value="✓ Clear deliverables &amp;amp; milestones defined per phase" style="text;html=1;strokeColor=none;fillColor=#ffffff;align=center;verticalAlign=middle;rounded=8;fontSize=10;fontColor=#1e293b;shadow=1;" parent="1" vertex="1">
                    <mxGeometry x="210" y="1262" width="340" height="34" as="geometry"/>
