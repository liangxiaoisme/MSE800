                <mxCell id="grp" value="Group W  ·  Abu Sufian  ·  Xiao Liang  ·  7 Weeks  ·  Healthcare Compliance &amp;amp; Safety" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=11;fontColor=#cbd5e1;" parent="1" vertex="1">
                    <mxGeometry x="40" y="66" width="1020" height="20" as="geometry"/>
