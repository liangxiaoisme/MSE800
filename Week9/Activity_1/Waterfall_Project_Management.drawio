        </mxCell>
        <mxCell id="p1_desc" value="&amp;bull; Gather HIPAA &amp; GDPR regulatory compliance needs&lt;br&gt;&amp;bull; Define 10 deliverable safety-reporting requirements&lt;br&gt;&amp;bull; Map user roles: Staff (training &amp; reporting) vs Admin (management)&lt;br&gt;&amp;bull; Non-functional: JWT auth, CORS, HTTPS, responsive design&lt;br&gt;&amp;bull; Document SRS with acceptance criteria for all business metrics" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=11;fontColor=#dbeafe;" vertex="1" parent="1">
          <mxGeometry height="100" width="280" x="60" y="315" as="geometry" />
