          <mxGeometry height="28" width="75" x="1800" y="495" as="geometry" />
        </mxCell>
        <mxCell id="p6_deliv_label" value="Deliverable:" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=10;fontColor=#6ee7b7;" vertex="1" parent="1">
          <mxGeometry height="16" width="250" x="1800" y="535" as="geometry" />
        </mxCell>
        <mxCell id="p6_deliv" value="Support &amp; SLA Agreement + Maintenance Log" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=12;fontColor=#ffffff;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry height="40" width="268" x="1800" y="552" as="geometry" />
        </mxCell>

        <!-- ===== KEY PRINCIPLES ===== -->
        <mxCell id="principles_bg" value="" style="rounded=8;arcSize=4;fillColor=#f1f5f9;strokeColor=#e2e8f0;strokeWidth=1;" vertex="1" parent="1">
          <mxGeometry height="110" width="2020" x="60" y="720" as="geometry" />
        </mxCell>
        <mxCell id="principles_title" value="Key Principles of Waterfall" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=17;fontStyle=1;fontColor=#1e293b;" vertex="1" parent="1">
          <mxGeometry height="28" width="280" x="90" y="730" as="geometry" />
        </mxCell>
        <mxCell id="princ_1" value="✓ Sequential,&lt;br&gt;structured phases" style="text;strokeColor=none;fillColor=#ffffff;align=center;verticalAlign=middle;rounded=8;fontSize=11;fontColor=#1e293b;shadow=1;" vertex="1" parent="1">
          <mxGeometry height="46" width="150" x="90" y="772" as="geometry" />
        </mxCell>
        <mxCell id="princ_2" value="✓ Each phase completes&lt;br&gt;before the next begins" style="text;strokeColor=none;fillColor=#ffffff;align=center;verticalAlign=middle;rounded=8;fontSize=11;fontColor=#1e293b;shadow=1;" vertex="1" parent="1">
          <mxGeometry height="46" width="170" x="258" y="772" as="geometry" />
        </mxCell>
        <mxCell id="princ_3" value="✓ Comprehensive&lt;br&gt;documentation at every stage" style="text;strokeColor=none;fillColor=#ffffff;align=center;verticalAlign=middle;rounded=8;fontSize=11;fontColor=#1e293b;shadow=1;" vertex="1" parent="1">
          <mxGeometry height="46" width="170" x="446" y="772" as="geometry" />
        </mxCell>
        <mxCell id="princ_4" value="✓ Clear deliverables&lt;br&gt;&amp; milestones per phase" style="text;strokeColor=none;fillColor=#ffffff;align=center;verticalAlign=middle;rounded=8;fontSize=11;fontColor=#1e293b;shadow=1;" vertex="1" parent="1">
          <mxGeometry height="46" width="160" x="634" y="772" as="geometry" />
        </mxCell>
        <mxCell id="princ_5" value="✓ Ideal for regulated&lt;br&gt;healthcare environments" style="text;strokeColor=none;fillColor=#ffffff;align=center;verticalAlign=middle;rounded=8;fontSize=11;fontColor=#1e293b;shadow=1;" vertex="1" parent="1">
          <mxGeometry height="46" width="170" x="812" y="772" as="geometry" />
        </mxCell>

