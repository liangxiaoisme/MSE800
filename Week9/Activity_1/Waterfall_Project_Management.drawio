                <mxCell id="kp4" value="✓ Ideal for regulated healthcare environments with fixed requirements" style="text;html=1;strokeColor=none;fillColor=#ffffff;align=center;verticalAlign=middle;rounded=8;fontSize=10;fontColor=#1e293b;shadow=1;" parent="1" vertex="1">
