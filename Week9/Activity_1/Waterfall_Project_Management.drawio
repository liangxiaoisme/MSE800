        </mxCell>
        <mxCell id="p2_desc" value="&amp;bull; 3-tier B/S architecture: React → Django API → PostgreSQL+pgvector&lt;br&gt;&amp;bull; OOP class hierarchy: 5 Django apps, User inheritance, Document-Chunk composition&lt;br&gt;&amp;bull; DB schema: 11 tables, pgvector VectorField(384), FK constraints, indexes&lt;br&gt;&amp;bull; API route design: 15+ REST endpoints with JWT &amp;amp; role-based permission rules&lt;br&gt;&amp;bull; UI/UX wireframes: 6 screens across Staff &amp;amp; Admin roles" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=11;fontColor=#ede9fe;" vertex="1" parent="1">
          <mxGeometry height="100" width="280" x="402" y="315" as="geometry" />
        </mxCell>
