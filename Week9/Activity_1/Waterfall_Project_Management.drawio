        </mxCell>
        <mxCell id="meta" value="Duration: 7 Weeks&amp;nbsp · &amp;nbsp Methodology: Waterfall SDLC&amp;nbsp · &amp;nbsp Domain: Healthcare Compliance &amp; Safety" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=15;fontColor=#cbd5e1;" vertex="1" parent="1">
          <mxGeometry height="30" width="800" x="662" y="90" as="geometry" />
        </mxCell>

        <!-- ===== PHASE 1: Requirements Analysis (blue) ===== -->
        <mxCell id="phase1" value="" style="rounded=12;arcSize=8;fillColor=#3b82f6;strokeColor=#2563eb;strokeWidth=2;shadow=1;" vertex="1" parent="1">
          <mxGeometry height="440" width="300" x="60" y="200" as="geometry" />
        </mxCell>
        <mxCell id="p1_num" value="01" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=40;fontStyle=1;fontColor=#ffffff;opacity=35;" vertex="1" parent="1">
          <mxGeometry height="50" width="100" x="240" y="215" as="geometry" />
        </mxCell>
        <mxCell id="p1_title" value="Requirements&lt;br&gt;Analysis" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=22;fontStyle=1;fontColor=#ffffff;" vertex="1" parent="1">
          <mxGeometry height="60" width="260" x="80" y="265" as="geometry" />
        </mxCell>
        <mxCell id="p1_desc" value="&amp;bull; Gather HIPAA / GDPR compliance &amp;amp; patient-privacy needs&lt;br&gt;&amp;bull; Stakeholder interviews: hospital administrators, clinical staff, safety officers&lt;br&gt;&amp;bull; Define 10 safety-reporting requirements &amp;amp; incident severity categories&lt;br&gt;&amp;bull; Map user roles &amp;amp; permissions: Staff (training, reporting) vs Admin (management)&lt;br&gt;&amp;bull; Non-functional: JWT auth, CORS, HTTPS encryption, responsive design&lt;br&gt;&amp;bull; Establish acceptance criteria for all 10 business metrics&lt;br&gt;&amp;bull; Document functional &amp;amp; non-functional specifications (SRS)" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=11;fontColor=#dbeafe;" vertex="1" parent="1">
          <mxGeometry height="150" width="268" x="80" y="330" as="geometry" />
        </mxCell>
        <mxCell id="p1_timeline" value="Week 1" style="text;fillColor=#1d4ed8;align=center;verticalAlign=middle;rounded=6;fontSize=12;fontColor=#ffffff;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry height="28" width="75" x="80" y="495" as="geometry" />
        </mxCell>
        <mxCell id="p1_deliv_label" value="Deliverable:" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=10;fontColor=#93c5fd;" vertex="1" parent="1">
          <mxGeometry height="16" width="250" x="80" y="535" as="geometry" />
        </mxCell>
        <mxCell id="p1_deliv" value="Software Requirements Specification (SRS) Document" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=12;fontColor=#ffffff;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry height="40" width="268" x="80" y="552" as="geometry" />
        </mxCell>

        <!-- Arrows between phases -->
        <mxCell id="arrow_1_2" value="" style="endArrow=block;endFill=1;endSize=12;html=1;strokeWidth=2;strokeColor=#64748b;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="363" y="420" as="sourcePoint" /><mxPoint x="393" y="420" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- ===== PHASE 2: System Design (purple) ===== -->
        <mxCell id="phase2" value="" style="rounded=12;arcSize=8;fillColor=#7c3aed;strokeColor=#6d28d9;strokeWidth=2;shadow=1;" vertex="1" parent="1">
          <mxGeometry height="440" width="300" x="396" y="200" as="geometry" />
        </mxCell>
        <mxCell id="p2_num" value="02" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=40;fontStyle=1;fontColor=#ffffff;opacity=35;" vertex="1" parent="1">
          <mxGeometry height="50" width="100" x="576" y="215" as="geometry" />
        </mxCell>
        <mxCell id="p2_title" value="System&lt;br&gt;Design" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=22;fontStyle=1;fontColor=#ffffff;" vertex="1" parent="1">
          <mxGeometry height="60" width="260" x="416" y="265" as="geometry" />
        </mxCell>
        <mxCell id="p2_desc" value="&amp;bull; Define 3-tier B/S architecture: React SPA → Django REST API → PostgreSQL+pgvector&lt;br&gt;&amp;bull; OOP class hierarchy: User(AbstractUser)→role enum, Document→Chunk composition, 5 Django apps&lt;br&gt;&amp;bull; Database schema: 11 tables across 5 apps, pgvector VectorField(384), indexes &amp;amp; FK constraints&lt;br&gt;&amp;bull; Design ERD + data-flow diagrams for all modules (training, compliance, incidents, chatbot)&lt;br&gt;&amp;bull; UI/UX wireframes: 6 screens (Login→Dashboard→Training→Compliance→Incidents→Chatbot)&lt;br&gt;&amp;bull; API route design: 15+ REST endpoints with JWT auth chain &amp;amp; role-based permission rules&lt;br&gt;&amp;bull; Security design: encrypted connections, bcrypt hashing, CORS isolation, token expiry policy" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=11;fontColor=#ede9fe;" vertex="1" parent="1">
          <mxGeometry height="150" width="268" x="416" y="330" as="geometry" />
        </mxCell>
        <mxCell id="p2_timeline" value="Week 2" style="text;fillColor=#6d28d9;align=center;verticalAlign=middle;rounded=6;fontSize=12;fontColor=#ffffff;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry height="28" width="75" x="416" y="495" as="geometry" />
        </mxCell>
        <mxCell id="p2_deliv_label" value="Deliverable:" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=10;fontColor=#c4b5fd;" vertex="1" parent="1">
          <mxGeometry height="16" width="250" x="416" y="535" as="geometry" />
        </mxCell>
        <mxCell id="p2_deliv" value="System Design Document (Architecture + ERD + Class Diagram + API Spec)" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=12;fontColor=#ffffff;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry height="40" width="268" x="416" y="552" as="geometry" />
        </mxCell>

        <mxCell id="arrow_2_3" value="" style="endArrow=block;endFill=1;endSize=12;html=1;strokeWidth=2;strokeColor=#64748b;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="699" y="420" as="sourcePoint" /><mxPoint x="729" y="420" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- ===== PHASE 3: Implementation (cyan) ===== -->
        <mxCell id="phase3" value="" style="rounded=12;arcSize=8;fillColor=#0891b2;strokeColor=#0e7490;strokeWidth=2;shadow=1;" vertex="1" parent="1">
          <mxGeometry height="440" width="340" x="732" y="200" as="geometry" />
        </mxCell>
        <mxCell id="p3_num" value="03" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=40;fontStyle=1;fontColor=#ffffff;opacity=35;" vertex="1" parent="1">
          <mxGeometry height="50" width="100" x="952" y="215" as="geometry" />
        </mxCell>
        <mxCell id="p3_title" value="Implementation&lt;br&gt;&amp; Development" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=22;fontStyle=1;fontColor=#ffffff;" vertex="1" parent="1">
          <mxGeometry height="60" width="300" x="752" y="265" as="geometry" />
        </mxCell>
        <mxCell id="p3_desc" value="&amp;bull; Scaffold Django 5 project: 5 apps (accounts, training, compliance, incidents, chatbot), DRF, SimpleJWT&lt;br&gt;&amp;bull; Implement 15+ REST API endpoints: auth + CRUD for training/compliance/incidents + chatbot ask&lt;br&gt;&amp;bull; Build React 18 + Vite SPA: React Router, Axios + JWT interceptor, 6-page UI with sidebar layout&lt;br&gt;&amp;bull; RAG chatbot pipeline: fastembed (bge-small-en, 384-dim) → pgvector L2Distance → OpenRouter Llama 4&lt;br&gt;&amp;bull; Compliance engine: quiz grading, on-read status computation (COMPLIANT/DUE/OVERDUE), incident workflow&lt;br&gt;&amp;bull; Seed database: 3 training modules × 3 questions, 3 compliance requirements, 5 knowledge-base documents&lt;br&gt;&amp;bull; Document ingestion: chunking (300 words, 50-overlap), embedding, pgvector bulk storage via management command" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=11;fontColor=#cffafe;" vertex="1" parent="1">
          <mxGeometry height="150" width="308" x="752" y="330" as="geometry" />
        </mxCell>
        <mxCell id="p3_timeline" value="Weeks 3 – 4" style="text;fillColor=#0e7490;align=center;verticalAlign=middle;rounded=6;fontSize=12;fontColor=#ffffff;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry height="28" width="100" x="752" y="495" as="geometry" />
        </mxCell>
        <mxCell id="p3_deliv_label" value="Deliverable:" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=10;fontColor=#a5f3fc;" vertex="1" parent="1">
          <mxGeometry height="16" width="250" x="752" y="535" as="geometry" />
        </mxCell>
        <mxCell id="p3_deliv" value="Fully Functional Source Code (Pre-Deployment) + RAG Pipeline Operational" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=12;fontColor=#ffffff;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry height="40" width="308" x="752" y="552" as="geometry" />
        </mxCell>

        <mxCell id="arrow_3_4" value="" style="endArrow=block;endFill=1;endSize=12;html=1;strokeWidth=2;strokeColor=#64748b;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1075" y="420" as="sourcePoint" /><mxPoint x="1105" y="420" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- ===== PHASE 4: Testing (orange) ===== -->
        <mxCell id="phase4" value="" style="rounded=12;arcSize=8;fillColor=#ea580c;strokeColor=#c2410c;strokeWidth=2;shadow=1;" vertex="1" parent="1">
          <mxGeometry height="440" width="300" x="1108" y="200" as="geometry" />
        </mxCell>
        <mxCell id="p4_num" value="04" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=40;fontStyle=1;fontColor=#ffffff;opacity=35;" vertex="1" parent="1">
          <mxGeometry height="50" width="100" x="1288" y="215" as="geometry" />
        </mxCell>
        <mxCell id="p4_title" value="Testing &amp;&lt;br&gt;Validation" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=22;fontStyle=1;fontColor=#ffffff;" vertex="1" parent="1">
          <mxGeometry height="60" width="260" x="1128" y="265" as="geometry" />
        </mxCell>
        <mxCell id="p4_desc" value="&amp;bull; Unit testing: Django test cases for each API endpoint (auth, CRUD, quiz submission, compliance computation)&lt;br&gt;&amp;bull; Integration testing: React ↔ Django ↔ PostgreSQL full-stack data-flow validation&lt;br&gt;&amp;bull; Security testing: JWT token expiry, role-based route protection, CORS origin validation, SQL injection&lt;br&gt;&amp;bull; RAG retrieval accuracy: top-5 relevance scoring, source-citation verification across 5 seed documents&lt;br&gt;&amp;bull; UAT: walk through all 10 business metrics — registration → training → compliance → incident → chatbot&lt;br&gt;&amp;bull; Cross-browser &amp;amp; responsive testing: Chrome, Firefox, Edge; desktop, tablet, mobile viewports" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=11;fontColor=#fef3c7;" vertex="1" parent="1">
          <mxGeometry height="150" width="268" x="1128" y="330" as="geometry" />
        </mxCell>
        <mxCell id="p4_timeline" value="Week 5" style="text;fillColor=#9a3412;align=center;verticalAlign=middle;rounded=6;fontSize=12;fontColor=#ffffff;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry height="28" width="75" x="1128" y="495" as="geometry" />
        </mxCell>
        <mxCell id="p4_deliv_label" value="Deliverable:" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=10;fontColor=#fed7aa;" vertex="1" parent="1">
          <mxGeometry height="16" width="250" x="1128" y="535" as="geometry" />
        </mxCell>
        <mxCell id="p4_deliv" value="Test &amp; QA Report (Unit + Integration + Security + UAT Sign-off)" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=12;fontColor=#ffffff;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry height="40" width="268" x="1128" y="552" as="geometry" />
        </mxCell>

        <mxCell id="arrow_4_5" value="" style="endArrow=block;endFill=1;endSize=12;html=1;strokeWidth=2;strokeColor=#64748b;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1411" y="420" as="sourcePoint" /><mxPoint x="1441" y="420" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- ===== PHASE 5: Deployment (red) ===== -->
        <mxCell id="phase5" value="" style="rounded=12;arcSize=8;fillColor=#dc2626;strokeColor=#b91c1c;strokeWidth=2;shadow=1;" vertex="1" parent="1">
          <mxGeometry height="440" width="300" x="1444" y="200" as="geometry" />
        </mxCell>
        <mxCell id="p5_num" value="05" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=40;fontStyle=1;fontColor=#ffffff;opacity=35;" vertex="1" parent="1">
          <mxGeometry height="50" width="100" x="1624" y="215" as="geometry" />
        </mxCell>
        <mxCell id="p5_title" value="Deployment&lt;br&gt;&amp; Go-Live" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=22;fontStyle=1;fontColor=#ffffff;" vertex="1" parent="1">
          <mxGeometry height="60" width="260" x="1464" y="265" as="geometry" />
        </mxCell>
        <mxCell id="p5_desc" value="&amp;bull; Deploy Django API to Render: Gunicorn, env vars (DATABASE_URL, SECRET_KEY, OPENROUTER_API_KEY), auto-migrate&lt;br&gt;&amp;bull; Deploy React SPA to Vercel: VITE_API_URL env var, SPA rewrite rules for client-side routing&lt;br&gt;&amp;bull; Provision Supabase PostgreSQL: enable pgvector extension, 500MB free tier, transaction-pooling (port 6543)&lt;br&gt;&amp;bull; Configure OpenRouter API key + run ingest_docs management command on Render production instance&lt;br&gt;&amp;bull; Render cold-start UX: frontend warm-up request → &amp;quot;Waking up server…&amp;quot; loading indicator → automatic retry&lt;br&gt;&amp;bull; Knowledge transfer: role-specific user guides (Staff / Admin), deployment &amp; operations README&lt;br&gt;&amp;bull; Phased go-live: smoke test on production, verify all CORS origins, confirm chatbot returns sourced answers" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=11;fontColor=#fee2e2;" vertex="1" parent="1">
          <mxGeometry height="150" width="268" x="1464" y="330" as="geometry" />
        </mxCell>
        <mxCell id="p5_timeline" value="Week 6" style="text;fillColor=#991b1b;align=center;verticalAlign=middle;rounded=6;fontSize=12;fontColor=#ffffff;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry height="28" width="75" x="1464" y="495" as="geometry" />
        </mxCell>
        <mxCell id="p5_deliv_label" value="Deliverable:" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=10;fontColor=#fca5a5;" vertex="1" parent="1">
          <mxGeometry height="16" width="250" x="1464" y="535" as="geometry" />
        </mxCell>
        <mxCell id="p5_deliv" value="Live System (Vercel + Render + Supabase) + Deployment &amp; Operations Guide" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=12;fontColor=#ffffff;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry height="40" width="268" x="1464" y="552" as="geometry" />
        </mxCell>

        <mxCell id="arrow_5_6" value="" style="endArrow=block;endFill=1;endSize=12;html=1;strokeWidth=2;strokeColor=#64748b;" edge="1" parent="1">
          <mxGeometry relative="1" as="geometry">
            <mxPoint x="1747" y="420" as="sourcePoint" /><mxPoint x="1777" y="420" as="targetPoint" />
          </mxGeometry>
        </mxCell>

        <!-- ===== PHASE 6: Maintenance (green) ===== -->
        <mxCell id="phase6" value="" style="rounded=12;arcSize=8;fillColor=#059669;strokeColor=#047857;strokeWidth=2;shadow=1;" vertex="1" parent="1">
          <mxGeometry height="440" width="300" x="1780" y="200" as="geometry" />
        </mxCell>
        <mxCell id="p6_num" value="06" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=40;fontStyle=1;fontColor=#ffffff;opacity=35;" vertex="1" parent="1">
          <mxGeometry height="50" width="100" x="1960" y="215" as="geometry" />
        </mxCell>
        <mxCell id="p6_title" value="Maintenance&lt;br&gt;&amp; Support" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=22;fontStyle=1;fontColor=#ffffff;" vertex="1" parent="1">
          <mxGeometry height="60" width="260" x="1800" y="265" as="geometry" />
        </mxCell>
        <mxCell id="p6_desc" value="&amp;bull; Continuous compliance monitoring: Render runtime logs, Supabase database performance dashboard&lt;br&gt;&amp;bull; Bug fixes &amp;amp; security updates: Django + React dependency patches, vulnerability remediation&lt;br&gt;&amp;bull; RAG model retraining &amp;amp; tuning: chunk size/overlap optimisation, prompt template iteration&lt;br&gt;&amp;bull; Regulatory change tracking: HIPAA / GDPR updates → compliance document revisions → knowledge-base refresh&lt;br&gt;&amp;bull; Periodic audits: user access reviews, API security scans, data-integrity verification&lt;br&gt;&amp;bull; Support SLA: 48-hr response for critical incidents, 1-week for feature requests" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontSize=11;fontColor=#d1fae5;" vertex="1" parent="1">
          <mxGeometry height="150" width="268" x="1800" y="330" as="geometry" />
        </mxCell>
