import sqlite3

def create_connection():
    conn = sqlite3.connect("money_exchange.db")
    return conn

def create_table():
    conn = create_connection()
    cursor = conn.cursor()
    
    # Users 表
    cursor.execute('''
        CREATE TABLE IF NOT EXISTS Users (
            user_id INTEGER PRIMARY KEY AUTOINCREMENT,
            user_email TEXT NOT NULL UNIQUE,
            user_phone TEXT,
            user_full_name TEXT NOT NULL,
            registration_date TIMESTAMP DEFAULT CURRENT_TIMESTAMP
        )
    ''')
    
    # Currency 表
    cursor.execute('''
        CREATE TABLE IF NOT EXISTS Currency (
            currency_id INTEGER PRIMARY KEY AUTOINCREMENT,
            currency_name TEXT NOT NULL,
            currency_symbol TEXT NOT NULL,
            currency_code TEXT NOT NULL UNIQUE,
            currency_country TEXT NOT NULL
        )
    ''')
    
    # ExchangeRate 表
    cursor.execute('''
        CREATE TABLE IF NOT EXISTS ExchangeRate (
            exchange_id INTEGER PRIMARY KEY AUTOINCREMENT,
            from_currency_id INTEGER NOT NULL,
            to_currency_id INTEGER NOT NULL,
            exchange_rate REAL NOT NULL,
            exchange_date TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
            FOREIGN KEY (from_currency_id) REFERENCES Currency(currency_id),
            FOREIGN KEY (to_currency_id) REFERENCES Currency(currency_id)
        )
    ''')
    
    # Transaction 表
    cursor.execute('''
        CREATE TABLE IF NOT EXISTS Transaction (
            transaction_id INTEGER PRIMARY KEY AUTOINCREMENT,
            user_id INTEGER NOT NULL,
            exchange_id INTEGER NOT NULL,
            transaction_fee REAL DEFAULT 0,
            transaction_status TEXT DEFAULT 'pending',
            transaction_date TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
            amount_from REAL NOT NULL,
            amount_to REAL NOT NULL,
            FOREIGN KEY (user_id) REFERENCES Users(user_id),
            FOREIGN KEY (exchange_id) REFERENCES ExchangeRate(exchange_id)
        )
    ''')
    
    # Log 表
    cursor.execute('''
        CREATE TABLE IF NOT EXISTS Log (
            log_id INTEGER PRIMARY KEY AUTOINCREMENT,
            transaction_id INTEGER NOT NULL,
            time_stamped TIMESTAMP DEFAULT CURRENT_TIMESTAMP,
            transaction_status TEXT NOT NULL,
            status_message TEXT,
            FOREIGN KEY (transaction_id) REFERENCES Transaction(transaction_id)
        )
    ''')
    
    conn.commit()
    conn.close()