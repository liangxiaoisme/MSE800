        <mxCell id="d_island" value="+ island : str" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=4;spacingRight=4;overflow=hidden;rotatable=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;" vertex="1" parent="domestic">
          <mxGeometry y="46" width="260" height="20" as="geometry" />
