<mxfile host="app.diagrams.net">
  <diagram name="Single Inheritance" id="anz-domestic-flight">
    <mxGraphModel dx="800" dy="600" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1100" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- ================= PARENT / BASE CLASS: Flight ================= -->
        <mxCell id="flight" value="Flight" style="swimlane;fontStyle=1;align=center;verticalAlign=top;childLayout=stackLayout;horizontal=1;startSize=26;horizontalStack=0;resizeParent=1;resizeParentMax=0;resizeLast=0;collapsible=1;marginBottom=0;" vertex="1" parent="1">
          <mxGeometry x="300" y="40" width="260" height="254" as="geometry" />
        </mxCell>
        <mxCell id="f_airline" value="+ airline : str = &quot;Air New Zealand&quot;  {static}" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=4;spacingRight=4;overflow=hidden;rotatable=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;" vertex="1" parent="flight">
          <mxGeometry y="26" width="260" height="20" as="geometry" />
        </mxCell>
        <mxCell id="f_num" value="+ flight_number : str" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=4;spacingRight=4;overflow=hidden;rotatable=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;" vertex="1" parent="flight">
          <mxGeometry y="46" width="260" height="20" as="geometry" />
        </mxCell>
        <mxCell id="f_origin" value="+ origin : str" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=4;spacingRight=4;overflow=hidden;rotatable=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;" vertex="1" parent="flight">
          <mxGeometry y="66" width="260" height="20" as="geometry" />
        </mxCell>
        <mxCell id="f_dest" value="+ destination : str" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=4;spacingRight=4;overflow=hidden;rotatable=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;" vertex="1" parent="flight">
          <mxGeometry y="86" width="260" height="20" as="geometry" />
        </mxCell>
        <mxCell id="f_cap" value="+ capacity : int" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=4;spacingRight=4;overflow=hidden;rotatable=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;" vertex="1" parent="flight">
          <mxGeometry y="106" width="260" height="20" as="geometry" />
        </mxCell>
        <mxCell id="f_fare" value="+ base_fare : float" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=4;spacingRight=4;overflow=hidden;rotatable=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;" vertex="1" parent="flight">
          <mxGeometry y="126" width="260" height="20" as="geometry" />
        </mxCell>
        <mxCell id="f_booked" value="+ booked_seats : int" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=4;spacingRight=4;overflow=hidden;rotatable=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;" vertex="1" parent="flight">
          <mxGeometry y="146" width="260" height="20" as="geometry" />
        </mxCell>
        <mxCell id="f_sep" value="" style="line;strokeWidth=1;fillColor=none;align=left;verticalAlign=middle;spacingTop=-1;spacingLeft=3;spacingRight=3;rotatable=0;labelPosition=right;points=[];portConstraint=eastwest;" vertex="1" parent="flight">
          <mxGeometry y="166" width="260" height="8" as="geometry" />
        </mxCell>
        <mxCell id="f_m_book" value="+ book_seat() : bool" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=4;spacingRight=4;overflow=hidden;rotatable=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;" vertex="1" parent="flight">
          <mxGeometry y="174" width="260" height="20" as="geometry" />
        </mxCell>
        <mxCell id="f_m_avail" value="+ available_seats() : int" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=4;spacingRight=4;overflow=hidden;rotatable=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;" vertex="1" parent="flight">
          <mxGeometry y="194" width="260" height="20" as="geometry" />
        </mxCell>
        <mxCell id="f_m_fare" value="+ calculate_fare() : float" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=4;spacingRight=4;overflow=hidden;rotatable=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;" vertex="1" parent="flight">
          <mxGeometry y="214" width="260" height="20" as="geometry" />
        </mxCell>
        <mxCell id="f_m_info" value="+ get_flight_info() : str" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=4;spacingRight=4;overflow=hidden;rotatable=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;" vertex="1" parent="flight">
          <mxGeometry y="234" width="260" height="20" as="geometry" />
        </mxCell>

        <!-- ================= CHILD / SUBCLASS: DomesticFlight ================= -->
        <mxCell id="domestic" value="DomesticFlight" style="swimlane;fontStyle=1;align=center;verticalAlign=top;childLayout=stackLayout;horizontal=1;startSize=26;horizontalStack=0;resizeParent=1;resizeParentMax=0;resizeLast=0;collapsible=1;marginBottom=0;" vertex="1" parent="1">
          <mxGeometry x="300" y="420" width="260" height="134" as="geometry" />
        </mxCell>
        <mxCell id="d_gst" value="+ GST_RATE : float = 0.15  {static}" style="text;strokeColor=none;fillColor=none;align=left;verticalAlign=top;spacingLeft=4;spacingRight=4;overflow=hidden;rotatable=0;points=[[0,0.5],[1,0.5]];portConstraint=eastwest;" vertex="1" parent="domestic">
